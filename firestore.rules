rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * - Public: Read access for QR code redirection (via Collection Group) and scan tracking.
 * - Users: Manage their own QR code history.
 * - Admin: Full Management of all records and roles.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); 
    }

    // 1. GLOBAL COLLECTION GROUP RULES
    // MUST be top-level for collectionGroup queries to work correctly.
    // This allows the /r/[qrId] engine to look up QR codes by ID for anyone.
    match /{path=**}/qr_codes/{qrCodeId} {
      // Allow public READ (get/list) so the redirect engine can find records.
      allow read: if true;
      
      // Allow public CREATE so users can generate codes anonymously.
      allow create: if true;

      // Allow public UPDATE only for tracking scans. 
      // We check that only analytics fields are being modified.
      allow update: if (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScans', 'lastScannedAt'])
      ) || isAdmin();

      // Only admins can delete records globally.
      allow delete: if isAdmin();
    }

    // 2. USER PROFILE RULES
    match /users/{userId} {
      allow get, create, update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      match /qr_codes/{qrCodeId} {
        // Users can list their own codes.
        allow list: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      }
    }

    // 3. ADMIN ROLE MANAGEMENT
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
    }
  }
}
