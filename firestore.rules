
rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * - Public: Read access for QR code redirection (via Collection Group) and scan tracking.
 * - Users: Manage their own QR code history (create/read).
 * - Admin: Full Management of all records and roles.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); 
    }

    // 1. GLOBAL COLLECTION GROUP RULES
    // This governs the /r/[qrId] redirect engine lookups.
    // We must allow 'list' (queries) and 'get' (direct fetch) globally.
    match /{path=**}/qr_codes/{qrCodeId} {
      allow read: if true;
      
      // Allow creation for anyone (anonymous or signed in)
      allow create: if true;

      // Allow public to update scan counts ONLY
      allow update: if (
        resource.data.status == 'active' 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScans', 'lastScannedAt'])
      ) || isAdmin();

      // Only admins can delete
      allow delete: if isAdmin();
    }

    // 2. USER PROFILE RULES
    match /users/{userId} {
      allow get, create, update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      // Note: The /qr_codes sub-collection rules are already covered by the global match above.
      // However, we can add specific 'list' restrictions for the Dashboard view if needed.
      match /qr_codes/{qrCodeId} {
        // Users can list their own codes in the dashboard
        allow list: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      }
    }

    // 3. ADMIN ROLE MANAGEMENT
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
    }
  }
}
