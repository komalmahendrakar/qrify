
rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * - Public: Generate QR (create) & Redirect (read via collectionGroup).
 * - Tracking: Public update of scan metrics on active links.
 * - Admin: Full Management (all operations).
 */

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); }

    match /users/{userId} {
      allow get, create, update: if isSignedIn() && request.auth.uid == userId || isAdmin();
      
      match /qr_codes/{qrCodeId} {
        // Public can read to find redirect info
        allow get, list: if true;

        // Any signed-in (including anonymous) user can create their own history
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

        // Public can ONLY update scan counts for active QR codes
        allow update: if (resource.data.status == 'active' 
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScans', 'lastScannedAt']))
          || isAdmin();

        allow delete: if isAdmin();
      }
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
    }

    // CRITICAL: Required for the /r/[qrId] redirect logic (Collection Group Query)
    // Allows looking up a QR code by its ID without knowing the parent userId path.
    match /{path=**}/qr_codes/{qrCodeId} {
      allow read: if true;
    }
  }
}
