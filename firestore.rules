
rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * - Public: Read access for QR code redirection (via Collection Group) and scan tracking.
 * - Users: Manage their own QR code history (create/read).
 * - Admin: Full Management of all records and roles.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); 
    }

    // 1. GLOBAL COLLECTION GROUP RULES
    // Crucial for /r/[qrId] redirect engine which uses collectionGroup queries.
    // This match pattern is required for collection group security.
    match /{path=**}/qr_codes/{qrCodeId} {
      // Allow public to find a QR code by ID and read its details for redirection.
      allow read: if true;
      
      // Allow creation for anyone (anonymous or signed in) so they can generate codes.
      allow create: if true;

      // Allow public to update scan counts ONLY if the code is active.
      // We explicitly check status and ensure ONLY analytics fields are modified.
      allow update: if (
        resource.data.status == 'active' 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScans', 'lastScannedAt'])
      ) || isAdmin();

      // Only admins can delete records globally.
      allow delete: if isAdmin();
    }

    // 2. USER PROFILE RULES
    match /users/{userId} {
      allow get, create, update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      // Users can list their own codes in the dashboard.
      match /qr_codes/{qrCodeId} {
        allow list: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      }
    }

    // 3. ADMIN ROLE MANAGEMENT
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
    }
  }
}
