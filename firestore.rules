rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * Optimized for Vercel Deployment & Public Redirection.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); 
    }

    // 1. GLOBAL COLLECTION GROUP RULES
    // Allows the redirect engine (/r/[qrId]) to find records across all users.
    // MUST be top-level and use recursive wildcard {path=**}.
    match /{path=**}/qr_codes/{qrCodeId} {
      // Public READ access for redirection lookup.
      allow read: if true;
      
      // Public CREATE for anonymous generation.
      allow create: if true;

      // Tracking updates (scan counts) allowed for anyone.
      allow update: if (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScans', 'lastScannedAt'])
      ) || (isSignedIn() && request.auth.uid == resource.data.userId) || isAdmin();

      // Deletion restricted to owners or admins.
      allow delete: if (isSignedIn() && request.auth.uid == resource.data.userId) || isAdmin();
    }

    // 2. USER PROFILE RULES
    match /users/{userId} {
      allow get, create, update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      match /qr_codes/{qrCodeId} {
        // Redundant read here is okay as collectionGroup rule covers it, 
        // but this allows direct path access if needed.
        allow read: if true;
      }
    }

    // 3. ADMIN ROLE MANAGEMENT
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
    }
  }
}
