rules_version = '2';

/**
 * FIRESTORE SECURITY RULES - PROTOTYPING MODE
 * 
 * Core Philosophy:
 * This ruleset implements a strict user-ownership model combined with administrative 
 * overrides. Security is enforced primarily through the hierarchical path structure 
 * (/users/{userId}/...) and verified against Firebase Authentication UIDs.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner and the document already exists. Used for updates and deletes. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Checks if the authenticated user has administrative privileges via a lookup. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the admin roles collection. Self-promotion is disallowed.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for the user metadata root.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false;

      /**
       * @description Rules for QR codes generated by a user.
       */
      match /qr_codes/{qrCodeId} {
        // Allow public read access for share links ONLY if the status is active
        // Owners and Admins can always read their/all documents regardless of status
        allow get: if (resource != null && resource.data.status == 'active') || isOwner(userId) || isAdmin();
        
        // Listing is restricted to owners and admins
        allow list: if isOwner(userId) || isAdmin();
        
        // Creation requires ownership and matching userId field
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId
          && request.resource.data.status == 'active'; // Default to active
          
        // Admins can update status, owners can update everything except userId
        allow update: if (isExistingOwner(userId) && request.resource.data.userId == resource.data.userId) || isAdmin();
        
        // Admins and owners can delete
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Collection Group rules for QR codes.
     * Public list access is allowed ONLY for the dynamic redirection service (/r/[id]).
     */
    match /{path=**}/qr_codes/{qrCodeId} {
      allow list: if isAdmin() || true; 
    }
  }
}
