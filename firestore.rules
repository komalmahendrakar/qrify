
rules_version = '2';

/**
 * FIRESTORE SECURITY RULES - PROTOTYPING MODE
 * 
 * Core Philosophy:
 * This ruleset implements a strict user-ownership model combined with administrative 
 * overrides. It also allows anonymous public updates for the scan tracking mechanism.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner and the document already exists. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Checks if the authenticated user has administrative privileges. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the admin roles collection.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for the user metadata root.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false;

      /**
       * @description Rules for QR codes. Supports public scan tracking for active codes.
       */
      match /qr_codes/{qrCodeId} {
        allow get: if (resource != null && resource.data.status == 'active') || isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId
          && request.resource.data.status == 'active';
          
        allow update: if 
          // 1. Allow public tracking updates if code is active (restricted to specific fields)
          (resource != null && resource.data.status == 'active' 
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScans', 'lastScannedAt']))
          // 2. Allow owner updates (except userId)
          || (isExistingOwner(userId) && request.resource.data.userId == resource.data.userId)
          // 3. Allow full admin updates
          || isAdmin();
        
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    match /{path=**}/qr_codes/{qrCodeId} {
      allow list: if isAdmin() || true; 
    }
  }
}
