rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * 
 * Provides public access for QR code generation and redirection,
 * while restricting administrative management to authorized users.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for admin roles.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
    }

    /**
     * @description Rules for user metadata and their nested QR codes.
     */
    match /users/{userId} {
      allow get, create, update: if isSignedIn() && request.auth.uid == userId || isAdmin();
      allow list: if isAdmin();

      match /qr_codes/{qrCodeId} {
        // 1. Read access: Publicly allowed for redirection logic and shared views.
        allow get, list: if true;

        // 2. Create access: Publicly allowed (requires sign-in, which includes anonymous).
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

        // 3. Update access: 
        // - Admins can update anything.
        // - Public can ONLY update 'totalScans' and 'lastScannedAt' for tracking purposes.
        allow update: if isAdmin() 
          || (resource.data.status == 'active' 
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScans', 'lastScannedAt']));

        // 4. Delete access: Strictly restricted to administrators.
        allow delete: if isAdmin();
      }
    }

    /**
     * @description Support for collection group queries.
     * Required for the dynamic redirection system (/r/[qrId]) and Admin Dashboard.
     */
    match /{path=**}/qr_codes/{qrCodeId} {
      allow read: if true;
    }
  }
}