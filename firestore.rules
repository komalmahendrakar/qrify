rules_version = '2';

/**
 * FIRESTORE SECURITY RULES - PROTOTYPING MODE
 * 
 * Core Philosophy:
 * This ruleset implements a strict user-ownership model combined with administrative 
 * overrides. Security is enforced primarily through the hierarchical path structure 
 * (/users/{userId}/...) and verified against Firebase Authentication UIDs.
 * 
 * Data Structure:
 * - /users/{userId}: Root document for each user.
 * - /users/{userId}/qr_codes/{qrCodeId}: Private subcollection for user-generated QR codes.
 * - /roles_admin/{adminId}: A lookup collection to identify users with administrative privileges.
 * 
 * Key Security Decisions:
 * 1. Authorization Independence: QR code documents denormalize the 'userId' field to allow 
 *    fast, independent security checks without parent document lookups.
 * 2. Administrative Access: Users whose UIDs exist in the '/roles_admin' collection are 
 *    granted read-only access to all user data for support and oversight.
 * 3. Public Sharing: QR codes can be read by anyone if they have the direct path (via share link).
 * 4. Structural Segregation: User data is kept in subcollections to simplify listing 
 *    logic and prevent accidental data leakage between users.
 * 5. Relational Integrity: On creation of a QR code, the rules enforce that the internal 
 *    'userId' field matches the authenticated user's ID and the document path.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner and the document already exists. Used for updates and deletes. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Checks if the authenticated user has administrative privileges via a lookup. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the admin roles collection. Self-promotion is disallowed.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for the user metadata root.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false;

      /**
       * @description Rules for QR codes generated by a user.
       */
      match /qr_codes/{qrCodeId} {
        // Allow public read access for share links
        allow get: if true;
        // Listing is restricted to owners and admins
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Collection Group rules for QR codes.
     */
    match /{path=**}/qr_codes/{qrCodeId} {
      allow list: if isAdmin();
    }
  }
}
