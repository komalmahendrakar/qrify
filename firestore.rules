
rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * - Public: Read access for QR code redirection (via Collection Group) and scan tracking.
 * - Users: Manage their own QR code history (create/read).
 * - Admin: Full Management of all records and roles.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); 
    }

    // 1. User and Admin specific rules for the hierarchical structure
    match /users/{userId} {
      // Users can manage their own profile and records
      allow get, create, update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      match /qr_codes/{qrCodeId} {
        // Individual document access
        allow get: if true;
        allow list: if (isSignedIn() && request.auth.uid == userId) || isAdmin();

        // Creation is public to allow anonymous generation
        allow create: if true;

        // Public can ONLY update scan counts for active QR codes. 
        // Admins have full update rights.
        allow update: if (
          resource.data.status == 'active' 
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScans', 'lastScannedAt'])
        ) || isAdmin();

        // Deletion restricted to admins
        allow delete: if isAdmin();
      }
    }

    // 2. Admin role management
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
    }

    // 3. COLLECTION GROUP RULES
    // CRITICAL: This allows the /r/[qrId] redirect engine to perform public lookups
    // across all sub-collections without needing to know the parent userId.
    match /{path=**}/qr_codes/{qrCodeId} {
      // 'read' allows both 'get' and 'list' (queries) for redirection logic
      allow read: if true;
      // Allow creation for anonymous generators
      allow create: if true;
    }
  }
}
